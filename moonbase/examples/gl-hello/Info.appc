[bundle]
id               = "show.blizzard.glhello"
name             = "GL Hello"
version          = "0.1.0"
minimum-moonbase = "1.0"
copyright        = "by Kyle Blizzard @ Blizzard.show"
category         = "utility"

[executable]
path                = "Contents/MacOS/gl-hello"
language            = "c"
render-mode-default = "gl"

[permissions]
filesystem = []
network    = []
hardware   = []
system     = []
ipc        = []

[localization]
base-locale       = "en"
supported-locales = ["en"]
