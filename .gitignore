# CopyCatOS — .gitignore
#
# Only code + README.md + LICENSE ship to GitHub. Everything else is local.

# ── Build artifacts ─────────────────────────────────────────────────
build/
*.o
*.a
*.so
*.dylib
*.dSYM/
.cache/
compile_commands.json

# ── System files ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
__pycache__/
*.pyc

# ── Every .md except the repo README ────────────────────────────────
# Enforce "only code + README.md" by globbing every .md then un-ignoring
# only the top-level README.md. CLAUDE.md, AGENTS.md, design docs, lessons,
# todos, memory notes, roadmaps — all stay local.
*.md
!README.md

# ── Copyrighted / reference material (local-only) ───────────────────
snowleopardaura/
icons/
tutorial/
screenshots/
wallpaper/
fonts/

# ── Claude / AI config (never ships) ────────────────────────────────
CLAUDE.md
AGENTS.md
.claude/
.codex/
memory/
tasks/
changelogforkyle.txt

# ── Archives ────────────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.dmg
zipBackups/

# ── Secrets / host info ─────────────────────────────────────────────
*.pem
*.key
*.pub
*.crt
.env
.env.*
*.credentials
id_rsa*
id_ed25519*
known_hosts
ssh_config
*.ssh

# ── Editor / IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
